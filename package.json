{
  "name": "faruk-resume",
  "version": "1.8.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node server.js",
    "dev:web": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "node server.js",
    "google:auth": "node scripts/google-auth.js",
    "github:secrets": "python scripts/setup-google-secrets.py",
    "sync:gmail": "powershell -ExecutionPolicy Bypass -File scripts/sync-gmail-to-production.ps1",
    "pdf": "node scripts/generate-resume-pdf.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright": "^1.52.0"
  }
}
